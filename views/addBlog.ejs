<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Add New Blog Page</title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>

    <div class="container">
        <form method="post" action="/blog/add-new" enctype="multipart/form-data">
            <div class="mt-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" class="form-control" id="title" name="title" aria-describedby="title">
            </div>

            <div class="mt-3">
                <label for="floatingTextarea">Body</label>
                <textarea class="form-control" name="body" placeholder="Enter your content here..." id="floatingTextarea"></textarea>
            </div>

            <div class="mt-3">
                <label for="coverImage" class="form-label">Cover Image</label>
                <input type="file" class="form-control" id="coverImage" name="coverImage" aria-describedby="coverImage">
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Submit</button>
            </div>
        </form>
    </div>

    <%- include('./partials/scripts.ejs') %>
</body>
</html>